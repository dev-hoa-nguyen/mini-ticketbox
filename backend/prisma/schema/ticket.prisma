// Định nghĩa trạng thái của từng vé cụ thể
enum TicketStatus {
  AVAILABLE // Vé đang trống, có thể đặt
  HOLD // Vé đang bị giữ trong vòng 5 phút
  SOLD // Vé đã bán thành công
}

model Ticket {
  id     String       @id @default(uuid())
  code   String       @unique // Mã vé duy nhất, ví dụ: VVIP-001, GA-250
  price  Decimal      @db.Decimal(10, 2)
  status TicketStatus @default(AVAILABLE)
  type   String       @default("")

  // Quan hệ N-1 với Order: một Order (giỏ vé) có thể chứa nhiều vé thuộc nhiều loại.
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // Trường version phục vụ cho Optimistic Locking nếu cần dùng làm phương án dự phòng
  version Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status]) // Tối ưu hóa truy vấn khi tìm kiếm các vé còn trống
  @@index([orderId]) // Truy vấn nhanh toàn bộ vé thuộc một Order (giỏ vé)
  @@map("tickets")
}
